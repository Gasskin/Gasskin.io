{
  "name": "pixai-tauri",
  "private": true,
  "version": "0.0.15",
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev": "vite",
    "dev:client": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit && vitest run",
    "dist": "pnpm tauri build",
    "codex": "node scripts/pixai-codex.mjs",
    "updater:local": "node scripts/local-updater.mjs",
    "updater:local:keygen": "node scripts/local-updater.mjs keygen",
    "updater:local:build": "node scripts/local-updater.mjs build",
    "updater:local:publish": "node scripts/local-updater.mjs publish",
    "updater:local:serve": "node scripts/local-updater.mjs serve",
    "updater:release": "node scripts/release-updater.mjs",
    "updater:release:keygen": "node scripts/release-updater.mjs keygen",
    "updater:release:pull-key": "node scripts/release-updater.mjs pull-key",
    "updater:release:build": "node scripts/release-updater.mjs build",
    "updater:release:manifest": "node scripts/release-updater.mjs manifest",
    "updater:release:publish": "node scripts/release-updater.mjs publish",
    "updater:release:publish-staged": "node scripts/release-updater.mjs publish-staged"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
